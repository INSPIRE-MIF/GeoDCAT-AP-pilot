  <!-- Constraint B: accessURL = endpointURL, dcat:accessService  -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <dcat:Distribution rdf:about="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795/distribution/wms">

    <!-- Mandatory – DCAT-AP 3.0 & HVD: Distribution dcat:accessURL                  -->
