<?xml version="1.0" encoding="UTF-8"?>
<!--
  ══════════════════════════════════════════════════════════════════
  DCAT-AP 3.0 HVD + GeoDCAT-AP 3.1.0  –  MINIMAL edition
  Only mandatory elements are included.
  Recommended and Optional elements are omitted.

  Source:   19139metadata-50b921ea-935e-d605-2287-4ee364046795.xml
  Dataset:  INSPIRE - Addresses (DK INSPIRE Addresses)
  Publisher: Klimadatastyrelsen

  Mandatory requirements covered:
  ┌─ DCAT-AP ──────────────────────────────────────────────────────┐
  │ Catalogue       : dct:title, dct:description, dct:publisher    │
  │ CatalogueRecord : dct:modified, foaf:primaryTopic              │
  │ Dataset         : dct:title, dct:description                   │
  │ DataService     : dct:title, dcat:endpointURL                  │
  │ Distribution    : dcat:accessURL                               │
  └────────────────────────────────────────────────────────────────┘
  ┌─ HVD (dcatap:) ────────────────────────────────────────────────┐
  │ Dataset + DataService + Distribution:                          │
  │   dcatap:applicableLegislation                                 │
  │   dcatap:hvdCategory                                           │
  │ DataService:                                                   │
  │   dcat:contactPoint                                            │
  │   foaf:page													   │
  └────────────────────────────────────────────────────────────────┘
  ┌─ Constraints ──────────────────────────────────────────────────┐
  │ A) DataService:dcat:servesDataset → Dataset                    │
  │ B) Distribution:dcat:accessService → DataService               │
  │    Distribution:dcat:accessURL = DataService:dcat:endpointURL  │
  └────────────────────────────────────────────────────────────────┘

  ISO 19139 → DCAT-AP mapping (mandatory elements only):
  gmd:fileIdentifier                    → dct:identifier (URI key)
  gmd:dateStamp                         → CatalogueRecord dct:modified [Mandatory – DCAT-AP 3.0]
  gmd:title + gmd:alternateTitle        → dct:title (da + en) [Mandatory – DCAT-AP 3.0]
  gmd:abstract                          → dct:description [Mandatory – DCAT-AP 3.0]
  gmd:pointOfContact (organisationName + email)
                                        → dct:publisher [Mandatory – DCAT-AP 3.0]
                                        → DataService dcat:contactPoint [Mandatory – HVD]
  gmd:keyword (EU legislation thesaurus, xlink:href)
                                        → dcatap:applicableLegislation [Mandatory – HVD]
  gmd:keyword (HVD categories thesaurus, xlink:href)
                                        → dcatap:hvdCategory [Mandatory – HVD]
  gmd:onLine (WWW:LINK, Dataforsyningen landing page)
                                        → foaf:page on DataService [Mandatory – HVD]
  gmd:onLine (protocol=17-069r3, function=download)
                                        → DataService endpointURL + Distribution accessURL [Mandatory – DCAT-AP 3.0 & HVD]
  gmd:onLine (protocol=ogc/wms, applicationProfile=view)
                                        → DataService endpointURL + Distribution accessURL [Mandatory – DCAT-AP 3.0 & HVD]
  gmd:onLine (protocol=rfc4287, applicationProfile=download)
                                        → Distribution accessURL (Atom feed, no DataService) [Mandatory – DCAT-AP 3.0 & HVD]
  gmd:applicationProfile (xlink:href)   → geodcatap:serviceType [Mandatory – GeoDCAT-AP 3.1.0]
  gmd:protocol (xlink:href)             → used only to identify service type during mapping
  ──────────────────────────────────────────────────────────────────
  Omitted (Recommended / Optional):
    dct:license, dct:accessRights, dct:spatial, dcat:bbox,
    dcat:spatialResolutionInMeters, dct:accrualPeriodicity,
    dct:language, dct:conformsTo (CRS / INSPIRE interop),
    dct:provenance, geodcatap:purpose, geodcatap:topicCategory,
    geodcatap:serviceProtocol, dcat:endpointDescription,
    dcat:landingPage, foaf:page (on Dataset), foaf:depiction,
    dct:format, dcat:mediaType, dcat:downloadURL, rdfs:seeAlso,
    dct:issued, skos:Concept stubs beyond hvdCategory
  ══════════════════════════════════════════════════════════════════
-->
<rdf:RDF
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xmlns:dcat="http://www.w3.org/ns/dcat#"
  xmlns:dct="http://purl.org/dc/terms/"
  xmlns:dcatap="http://data.europa.eu/r5r/"
  xmlns:eli="http://data.europa.eu/eli/ontology#"
  xmlns:foaf="http://xmlns.com/foaf/0.1/"
  xmlns:vcard="http://www.w3.org/2006/vcard/ns#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:geodcatap="http://data.europa.eu/930/"
>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- CATALOGUE                                                    -->
  <!-- Mandatory: dct:title, dct:description, dct:publisher        -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <dcat:Catalog rdf:about="https://geodata-info.dk/srv/api">

    <!-- Mandatory – DCAT-AP 3.0: Catalogue dct:title -->
    <dct:title xml:lang="da">Danmarks Geodata-katalog</dct:title>

    <!-- Mandatory – DCAT-AP 3.0: Catalogue dct:description -->
    <dct:description xml:lang="da">Den nationale geoportal for Danmarks officielle geodata administreret af Klimadatastyrelsen.</dct:description>

    <!-- Mandatory – DCAT-AP 3.0: Catalogue dct:publisher -->
    <dct:publisher rdf:resource="https://www.kds.dk"/>

    <!-- Links to catalogue members -->
    <dcat:dataset rdf:resource="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795"/>
    <dcat:record  rdf:resource="https://geodata-info.dk/srv/api/records/50b921ea-935e-d605-2287-4ee364046795/catalogueRecord"/>
    <!-- Mandatory – DCAT-AP 3.0 (Catalogue): dcat:service for both DataServices -->
    <dcat:service rdf:resource="https://geo.data.gov.dk/dataservice/ogcapi-features/ad_inspire"/>
    <dcat:service rdf:resource="https://geo.data.gov.dk/dataservice/wms/ad_inspire"/>

  </dcat:Catalog>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- CATALOGUE RECORD                                            -->
  <!-- Mandatory: dct:modified, foaf:primaryTopic                  -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <dcat:CatalogRecord rdf:about="https://geodata-info.dk/srv/api/records/50b921ea-935e-d605-2287-4ee364046795/catalogueRecord">

    <!-- Mandatory – DCAT-AP 3.0: CatalogueRecord dct:modified                      -->
    <!-- gmd:dateStamp → dct:modified                              -->
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-27T11:09:16Z</dct:modified>

    <!-- Mandatory – DCAT-AP 3.0: CatalogueRecord foaf:primaryTopic                 -->
    <foaf:primaryTopic rdf:resource="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795"/>

  </dcat:CatalogRecord>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- PUBLISHER (foaf:Agent)                                      -->
  <!-- Mandatory – DCAT-AP 3.0: foaf:name required on Agent                         -->
  <!-- gmd:contact/gmd:CI_ResponsibleParty → foaf:Organization    -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <foaf:Organization rdf:about="https://www.kds.dk">
    <!-- gmd:organisationName → foaf:name -->
    <foaf:name xml:lang="da">Klimadatastyrelsen</foaf:name>
  </foaf:Organization>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- DATASET                                                     -->
  <!-- Mandatory – DCAT-AP 3.0: dct:title, dct:description                         -->
  <!-- Mandatory – HVD:  dcatap:applicableLegislation, dcatap:hvdCategory   -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <dcat:Dataset rdf:about="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795">

    <!-- Mandatory – DCAT-AP 3.0: Dataset dct:title                                 -->
    <!-- gmd:title → dct:title (da)                               -->
    <!-- gmd:alternateTitle → dct:title (en)                      -->
    <dct:title xml:lang="da">INSPIRE - Adresser</dct:title>
    <dct:title xml:lang="en">DK INSPIRE Addresses</dct:title>

    <!-- Mandatory – DCAT-AP 3.0: Dataset dct:description                           -->
    <!-- gmd:abstract → dct:description                           -->
    <dct:description xml:lang="da">Dette INSPIRE datasæt viser adresser. Data kan anvendes alene eller i kombination med andre data fra Danmark og Europa til analyser af f.eks. risici for oversvømmelser, forurening og værdisætning.</dct:description>

    <!-- dct:identifier – strongly recommended; most validators expect it -->
    <!-- gmd:identifier/CI_Citation/gmd:code (xlink:href) → dct:identifier -->
    <dct:identifier>https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795</dct:identifier>

    <!-- Mandatory – DCAT-AP 3.0: dct:publisher (inherited from Catalogue, repeated here for clarity) -->
    <dct:publisher rdf:resource="https://www.kds.dk"/>

    <!-- Mandatory – HVD: Dataset dcatap:applicableLegislation               -->
    <!-- gmd:descriptiveKeywords (EU legislation thesaurus):       -->
    <!--   xlink:href=http://data.europa.eu/eli/reg_impl/2023/138/oj  (HVD Regulation)    -->
    <!--   xlink:href=http://data.europa.eu/eli/dir/2007/2/2019-06-26 (INSPIRE Directive) -->
    <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/reg_impl/2023/138/oj"/>
    <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/dir/2007/2/2019-06-26"/>

    <!-- Mandatory – HVD: Dataset dcatap:hvdCategory                        -->
    <!-- gmd:descriptiveKeywords (HVD categories thesaurus):      -->
    <!--   xlink:href=http://data.europa.eu/bna/c_c3de25e4  (Addresses)      -->
    <!--   xlink:href=http://data.europa.eu/bna/c_ac64a52d  (Geospatial data)-->
    <dcatap:hvdCategory rdf:resource="http://data.europa.eu/bna/c_c3de25e4"/>
    <dcatap:hvdCategory rdf:resource="http://data.europa.eu/bna/c_ac64a52d"/>

    <!-- Links to distributions -->
    <dcat:distribution rdf:resource="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795/distribution/ogcapi-features"/>
    <dcat:distribution rdf:resource="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795/distribution/wms"/>
    <dcat:distribution rdf:resource="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795/distribution/atom"/>

  </dcat:Dataset>

  <!-- ════════════════════════════════════════════════════════════ -->
  <!-- DATASERVICE 1: OGC API Features                            -->
  <!-- Mandatory – DCAT-AP 3.0:   dct:title, dcat:endpointURL                      -->
  <!-- Mandatory – HVD:    dcatap:applicableLegislation, dcatap:hvdCategory,-->
  <!--           dcat:contactPoint, foaf:page                     -->
  <!-- Mandatory – GeoDCAT-AP 3.1.0: geodcatap:serviceType                           -->
  <!-- Constraint A: dcat:servesDataset                           -->
  <!-- ════════════════════════════════════════════════════════════ -->
  <dcat:DataService rdf:about="https://geo.data.gov.dk/dataservice/ogcapi-features/ad_inspire">

    <!-- Mandatory – DCAT-AP 3.0: DataService dct:title                             -->
    <dct:title xml:lang="da">OGC API Features – INSPIRE Adresser</dct:title>

    <!-- Mandatory – DCAT-AP 3.0 & HVD: DataService dcat:endpointURL                 -->
    <!-- gmd:onLine/gmd:linkage (protocol xlink:href=17-069r3) → endpointURL -->
    <dcat:endpointURL rdf:resource="https://api.dataforsyningen.dk/ogcapi/features/ad_inspire"/>

    <!-- Mandatory – HVD: DataService dcatap:applicableLegislation          -->
    <!-- gmd:descriptiveKeywords (EU legislation thesaurus) → xlink:href -->
    <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/reg_impl/2023/138/oj"/>
    <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/dir/2007/2/2019-06-26"/>

    <!-- Mandatory – HVD: DataService dcatap:hvdCategory                    -->
    <!-- gmd:descriptiveKeywords (HVD categories thesaurus) → xlink:href -->
    <dcatap:hvdCategory rdf:resource="http://data.europa.eu/bna/c_c3de25e4"/>
    <dcatap:hvdCategory rdf:resource="http://data.europa.eu/bna/c_ac64a52d"/>

    <!-- Mandatory – HVD: DataService dcat:contactPoint                     -->
    <!-- gmd:pointOfContact (role=owner):                         -->
    <!--   gmd:organisationName → vcard:fn                        -->
    <!--   gmd:electronicMailAddress → vcard:hasEmail             -->
    <dcat:contactPoint>
      <vcard:Organization>
        <vcard:fn>Klimadatastyrelsen</vcard:fn>
        <vcard:hasEmail rdf:resource="mailto:support@kds.dk"/>
      </vcard:Organization>
    </dcat:contactPoint>

    <!-- Mandatory – HVD: DataService foaf:page (human-readable documentation page) -->
    <!-- gmd:onLine (protocol=WWW:LINK, name="Destinationsside på Dataforsyningen") → foaf:page -->
    <foaf:page rdf:resource="https://dataforsyningen.dk/data/3937"/>

    <!-- Constraint A (HVD): dcat:servesDataset → Dataset URI     -->
    <dcat:servesDataset rdf:resource="https://geo.data.gov.dk/dataset/50b921ea-935e-d605-2287-4ee364046795"/>

    <!-- Mandatory – GeoDCAT-AP 3.1.0: geodcatap:serviceType                         -->
    <!-- gmd:applicationProfile xlink:href=SpatialDataServiceType/other -->
    <!-- (OGC API Features is classified as a download service)   -->
    <geodcatap:serviceType rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceType/download"/>

  </dcat:DataService>

  <!-- ════════════════════════════════════════════════════════════ -->
